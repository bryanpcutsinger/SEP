# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
ENV/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# IDE / editor folders
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Data files (keep raw/processed dirs via .gitkeep but ignore large data)
*.csv
*.xlsx
*.xls
*.parquet
*.feather
*.h5
*.hdf5

# Output artifacts (regenerated from code)
output/*.png
output/*.pdf
output/*.html

# Environment variables
.env
